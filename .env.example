# Copy this file to .env. Never commit a real .env file.

# Embedding and generation providers are selected independently: gemini or ollama.
EMBEDDING_PROVIDER=gemini
GENERATION_PROVIDER=gemini

# Gemini credentials and models. Leave the key empty until making a real Gemini call.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite

# Ollama is installed and started separately by the user.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=30

# Paths may be absolute or relative to the project root.
DOCUMENTS_DIR=data/documents
VECTOR_STORE_DIR=data/vector_store

CHUNK_SIZE=200
CHUNK_OVERLAP=50
TOP_K=4

# JSON/JSONL extraction configuration.
JSON_EXTRACTION_MODE=auto
JSON_CONTENT_KEYS=content,text,body,description,summary,answer,paragraph,paragraphs
JSON_TITLE_KEYS=title,heading,name,question
JSON_METADATA_KEYS=id,url,author,category,tags,language,status,version,created_at,updated_at
JSON_EXCLUDE_KEYS=embedding,embeddings,vector,vectors,raw_html,base64,image
JSON_MAX_DEPTH=20
JSON_MAX_RECORDS=1000
JSON_MAX_FILE_SIZE_MB=10
JSON_STRICT_MODE=true