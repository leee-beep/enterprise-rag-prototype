# Copy this file to .env in the project root.
# Replace only the fake API key below; never commit your real .env file.
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model used later for grounded answer generation.
GEMINI_GENERATION_MODEL=gemini-3.1-flash-lite

# Gemini model used later to convert text into vectors.
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# Paths may be absolute or relative to the project root.
DOCUMENTS_DIR=data/documents
VECTOR_STORE_DIR=data/vector_store

# Planned text-splitting settings. CHUNK_OVERLAP must be smaller than CHUNK_SIZE.
CHUNK_SIZE=200
CHUNK_OVERLAP=50

# Number of document chunks the future retriever should return.
TOP_K=4
# JSON/JSONL extraction mode: auto, record, or recursive.
JSON_EXTRACTION_MODE=auto
# Comma-separated, case-insensitive field names.
JSON_CONTENT_KEYS=content,text,body,description,summary,answer,paragraph,paragraphs
JSON_TITLE_KEYS=title,heading,name,question
JSON_METADATA_KEYS=id,url,author,category,tags,language,status,version,created_at,updated_at
# Large/binary/vector fields that must never become document text.
JSON_EXCLUDE_KEYS=embedding,embeddings,vector,vectors,raw_html,base64,image
# Safety limits for local ingestion.
JSON_MAX_DEPTH=20
JSON_MAX_RECORDS=1000
JSON_MAX_FILE_SIZE_MB=10
# true: fail immediately; false: skip invalid records and return warnings.
JSON_STRICT_MODE=true